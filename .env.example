# 复制为 .env 并填入真实 Key
# 任意 OpenAI 兼容 API：填写 URL + Key + 模型名即可

# --- 方式 A：通用 OpenAI 兼容（推荐）---
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- 方式 B：阿里云百炼（亦兼容 OpenAI 接口）---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=deepseek-r1

# --- 方式 C：本地 Ollama（无需 Key）---
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# 也可在 Web 界面「API 设置」中可视化配置，无需手动编辑 .env

# LLM 输入体积预检（字符数，可按 API 调整）
# LLM_MAX_INPUT_CHARS=90000
# LLM_WARN_INPUT_CHARS=75000

# 多 Agent 深研：设为 0 / false / no 可关闭并行 Agent（调试用）
# RESEARCH_PARALLEL_AGENTS=1

# 语义规划：规则 + LLM 任务拆分（映射表仅参考）。设为 0 则纯规则回退
# SEMANTIC_LLM_PLANNER=1
